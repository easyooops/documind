{
  "description": "QA Critic - VLM-based visual fidelity feedback loop",
  "provider_type": "vlm",
  "llm": {
    "model": "gpt-4o",
    "temperature": 0.2,
    "max_tokens": 2048,
    "top_p": 1.0
  },
  "qa": {
    "fidelity_threshold": 0.88,
    "ssim_pre_gate": 0.70,
    "max_iterations": 2
  },
  "retry": {
    "max_attempts": 3,
    "backoff_seconds": 1
  },
  "output_format": "json"
}
