{
  "$id": "image",
  "version": "1.0.0",
  "description": "Image/icon rules — placement, sizing, and placeholder constraints",
  "types": {
    "photo": {
      "min_size_px": { "width": 100, "height": 80 },
      "max_size_px": { "width": 600, "height": 400 },
      "aspect_ratios": ["16:9", "4:3", "1:1", "3:2"],
      "position": "body_region"
    },
    "icon": {
      "size_range_px": [24, 64],
      "square_only": true,
      "color_mode": "monochrome_or_duotone",
      "position": "inline_or_decorative"
    },
    "logo": {
      "max_width_px": 200,
      "max_height_px": 80,
      "position": ["header", "footer"],
      "background": "transparent"
    },
    "placeholder": {
      "description": "Placeholder shape indicating image position",
      "fill_color": "#F3F4F6",
      "border_color": "#D1D5DB",
      "icon": "image_outline",
      "label": "Image Placeholder"
    }
  },
  "constraints": {
    "max_images_per_slide": 4,
    "max_total_area_ratio": 0.5,
    "min_margin_from_text_px": 12,
    "overlap_with_text": false
  },
  "ooxml_mapping": {
    "element": "p:pic",
    "relationship": "r:embed",
    "stretch_fill": "a:stretch/a:fillRect",
    "supported_formats": ["png", "jpg", "svg", "emf"]
  }
}
