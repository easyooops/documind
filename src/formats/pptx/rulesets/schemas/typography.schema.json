{
  "$id": "typography",
  "version": "1.0.0",
  "description": "Typography rules — fonts, sizes, line-height, and text fitting",
  "fonts": {
    "allowed": ["Pretendard", "Noto Sans KR", "Inter", "Aptos", "Segoe UI"],
    "heading": "Pretendard",
    "body": "Pretendard",
    "monospace": "JetBrains Mono",
    "fallback": "system-ui, sans-serif"
  },
  "scale": {
    "title": { "min_px": 36, "max_px": 48, "weight": 700, "role": "Slide main title" },
    "heading": { "min_px": 24, "max_px": 32, "weight": 700, "role": "Section heading" },
    "subheading": { "min_px": 18, "max_px": 22, "weight": 600, "role": "Subtitle/separator" },
    "body": { "min_px": 13, "max_px": 16, "weight": 400, "role": "Body text" },
    "caption": { "min_px": 10, "max_px": 12, "weight": 400, "role": "Caption/annotation" },
    "label": { "min_px": 9, "max_px": 11, "weight": 500, "role": "Data label/tag" },
    "kpi_value": { "min_px": 28, "max_px": 42, "weight": 700, "role": "KPI value emphasis" }
  },
  "line_height": {
    "title": { "min": 1.1, "max": 1.3, "default": 1.2 },
    "body": { "min": 1.3, "max": 1.8, "default": 1.5 },
    "caption": { "min": 1.2, "max": 1.4, "default": 1.3 }
  },
  "letter_spacing": {
    "title": { "min": -0.5, "max": 0.5, "unit": "px" },
    "body": { "min": 0, "max": 0.3, "unit": "px" }
  },
  "text_fitting": {
    "korean_char_width_ratio": 0.9,
    "latin_char_width_ratio": 0.55,
    "max_chars_per_role": {
      "title": 25,
      "heading": 35,
      "subheading": 45,
      "body_per_line": 40
    },
    "max_lines": {
      "title": 2,
      "heading": 2,
      "subheading": 2,
      "body_block": 8,
      "bullet_item": 3
    },
    "overflow_actions": ["truncate_with_ellipsis", "reduce_font_size", "split_lines"],
    "min_font_reduction_px": 2
  },
  "weight_rules": {
    "title_must_be_bold": true,
    "body_should_be_regular": true,
    "allowed_weights": [400, 500, 600, 700],
    "max_bold_elements_ratio": 0.3
  }
}
