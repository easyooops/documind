# ═══════════════════════════════════════════════════════════════════════════════
# DocuMind - Connection Configuration
#
# This file contains ONLY connection/authentication settings.
# Model selection and LLM parameters are managed in:
#   src/agents/configs/_default.json  (global default model)
#   src/agents/configs/{agent}.json   (per-agent overrides)
#
# PROVIDER SELECTION:
#   Set LLM_PROVIDER to one of:
#     openai | anthropic | azure | bedrock | gcp_vertex | gemini | ollama | vllm | custom
#
# AUTHENTICATION PRIORITY (example for AWS):
#   1. Explicit keys in this file (AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY)
#   2. Named profile (AWS_PROFILE=my-profile)
#   3. Environment variables (standard AWS_* vars from shell)
#   4. Shared credentials file (~/.aws/credentials)
#   5. IAM Instance Role / ECS Task Role / IRSA (auto-detected by SDK)
#
# Similar fallback chains apply to GCP (ADC) and Azure (DefaultAzureCredential).
# ═══════════════════════════════════════════════════════════════════════════════

# ═══ PROVIDER SELECTION ═══
# Which LLM backend to use for all agents.
# Options: openai | anthropic | azure | bedrock | gcp_vertex | gemini | ollama | vllm | custom
LLM_PROVIDER=bedrock

# ═══════════════════════════════════════════════════════════════════════════════
# DEFAULT MODEL CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# When USE_DEFAULT_MODELS=true, ALL agents use the default models below
# (matched by their provider_type: llm, vlm, or image).
# Individual agent configs still control parameters (temperature, max_tokens, etc.).
#
# When USE_DEFAULT_MODELS=false, each agent uses its own model from its config file.
# This toggle allows quick model switching across all agents without editing
# individual config files — ideal for deployment or testing different models.
USE_DEFAULT_MODELS=true

# Default text generation model (provider_type=llm)
# Used by: research, narrative, audience, content_writer, layout_composer,
#          style_director, asset_planner, code_generator, consistency
# Bedrock cross-region inference profile (requires model access in AWS console)
DEFAULT_LLM_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0
# DEFAULT_LLM_MODEL=global.anthropic.claude-sonnet-4-5-20250929-v1:0
# DEFAULT_LLM_MODEL=global.anthropic.claude-opus-4-6-v1

# Default vision-language model (provider_type=vlm)
# Used by: template_analysis, validation, qa_critic
DEFAULT_VLM_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0
# DEFAULT_VLM_MODEL=global.anthropic.claude-sonnet-4-5-20250929-v1:0
# DEFAULT_VLM_MODEL=global.anthropic.claude-opus-4-6-v1

# Default image generation model (provider_type=image)
# Used by: future image generation agents
DEFAULT_IMAGE_MODEL=amazon.nova-canvas-v1:0

# ═══════════════════════════════════════════════════════════════════════════════
# OPENAI
# ═══════════════════════════════════════════════════════════════════════════════
# Standard OpenAI API. Also works with any OpenAI-compatible proxy.
# Auth: API key only.
OPENAI_API_KEY=
# Optional: override base URL for proxies (e.g., LiteLLM, Helicone)
OPENAI_BASE_URL=

# ═══════════════════════════════════════════════════════════════════════════════
# ANTHROPIC (Claude Direct)
# ═══════════════════════════════════════════════════════════════════════════════
# Direct connection to Anthropic's Claude API.
# Auth: API key only.
ANTHROPIC_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# AZURE OPENAI
# ═══════════════════════════════════════════════════════════════════════════════
# Azure-hosted OpenAI models.
# Auth methods (in priority order):
#   1. API Key (AZURE_OPENAI_API_KEY)
#   2. Azure AD / DefaultAzureCredential (leave API key blank)
#      - Works with Managed Identity, CLI login, env vars, etc.
AZURE_OPENAI_API_KEY=
# Full endpoint URL, e.g., https://my-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=
# API version (see Azure docs for latest)
AZURE_OPENAI_API_VERSION=2024-06-01
# Deployment name (maps to the model you deployed in Azure portal)
AZURE_OPENAI_DEPLOYMENT=

# ═══════════════════════════════════════════════════════════════════════════════
# AWS BEDROCK
# ═══════════════════════════════════════════════════════════════════════════════
# AWS Bedrock for Claude, Titan, Llama, Mistral, etc.
# Auth methods (in priority order, standard AWS SDK chain):
#   1. Explicit credentials below (AWS_ACCESS_KEY_ID + SECRET)
#   2. Named profile (AWS_PROFILE) from ~/.aws/credentials
#   3. Environment variables (AWS_ACCESS_KEY_ID, etc. from shell)
#   4. AWS config file (~/.aws/config) with role_arn, sso, etc.
#   5. EC2 Instance Metadata / ECS Task Role / IRSA (K8s)
#
# For local development: use AWS_PROFILE or explicit keys.
# For production (EC2/ECS/EKS): leave all blank, SDK auto-discovers IAM role.
# Global inference models (global.*) typically use us-east-1 or us-west-2.
AWS_REGION=us-east-1
# Option A: Named profile (recommended for local dev with SSO/MFA)
AWS_PROFILE=
# Option B: Explicit credentials (CI/CD or service accounts)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
# Option C: Assume role ARN (cross-account or elevated permissions)
AWS_ROLE_ARN=
AWS_BEDROCK_CONNECT_TIMEOUT=10
AWS_BEDROCK_READ_TIMEOUT=180
AWS_BEDROCK_MAX_ATTEMPTS=3

# ═══════════════════════════════════════════════════════════════════════════════
# GCP VERTEX AI
# ═══════════════════════════════════════════════════════════════════════════════
# Google Cloud Vertex AI (Gemini, PaLM, Claude on Vertex, etc.)
# Auth methods (Application Default Credentials chain):
#   1. GOOGLE_APPLICATION_CREDENTIALS file path (service account JSON)
#   2. gcloud CLI login (gcloud auth application-default login)
#   3. Metadata server (GCE, GKE, Cloud Run - auto-detected)
#   4. Workload Identity Federation
#
# For local development: run `gcloud auth application-default login`
# For production (GKE/Cloud Run): leave blank, ADC auto-discovers.
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
# Optional: explicit path to service account key file
GOOGLE_APPLICATION_CREDENTIALS=

# ═══════════════════════════════════════════════════════════════════════════════
# GOOGLE GEMINI (API Key)
# ═══════════════════════════════════════════════════════════════════════════════
# Google Gemini via simple API key (non-Vertex, Google AI Studio).
# Auth: API key only.
GOOGLE_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# SELF-HOSTED / ON-PREMISE (Ollama, vLLM, TGI, LocalAI, etc.)
# ═══════════════════════════════════════════════════════════════════════════════
# Any model served with an OpenAI-compatible API.
# Set LLM_PROVIDER=ollama for Ollama, or LLM_PROVIDER=vllm / custom for others.
# Auth: optional API key (if your endpoint requires one).
CUSTOM_LLM_BASE_URL=http://localhost:11434/v1
CUSTOM_LLM_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════════════════
# Supported: sqlite | postgresql
# SQLite requires no additional config (zero-setup local).
DATABASE_TYPE=sqlite
DATABASE_PATH=./data/documind.db
# PostgreSQL connection (uncomment and fill when DATABASE_TYPE=postgresql)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=documind
# DB_USER=documind
# DB_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════════
# FILE STORAGE
# ═══════════════════════════════════════════════════════════════════════════════
# Where generated documents are stored.
# Options: local | s3
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/outputs
# S3 (uses same AWS credentials from BEDROCK section above)
# AWS_S3_BUCKET=
# AWS_S3_REGION=

# ═══════════════════════════════════════════════════════════════════════════════
# APPLICATION SERVER
# ═══════════════════════════════════════════════════════════════════════════════
APP_PORT=8000
APP_ENV=development
LOG_LEVEL=INFO
# Backend log file (empty = terminal only). View while dev server runs.
LOG_FILE=data/logs/documind.log
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
