# Image tags
DOCUMIND_API_IMAGE=documind/api:0.2.0
DOCUMIND_WEB_IMAGE=documind/web:0.2.0

# Host port bindings
DOCUMIND_API_HOST_PORT=8000
DOCUMIND_WEB_HOST_PORT=3000

# App
APP_ENV=production
APP_PORT=8000
LOG_LEVEL=INFO
LOG_FILE=/var/lib/documind/logs/documind.log
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Database: sqlite | postgresql
DATABASE_TYPE=sqlite
DATABASE_PATH=/var/lib/documind/documind.db
# DB_HOST=
# DB_PORT=5432
# DB_NAME=documind
# DB_USER=documind
# DB_PASSWORD=

# Storage: local | s3
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/var/lib/documind/outputs
# AWS_S3_BUCKET=
# AWS_S3_REGION=ap-northeast-2

# LLM provider
LLM_PROVIDER=bedrock
USE_DEFAULT_MODELS=true
DEFAULT_LLM_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0
DEFAULT_VLM_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0
DEFAULT_IMAGE_MODEL=amazon.titan-image-generator-v2:0

# Provider credentials. Prefer IAM role on EC2 for Bedrock and S3.
AWS_REGION=us-east-1
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_ROLE_ARN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_DEPLOYMENT=
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
CUSTOM_LLM_BASE_URL=http://localhost:11434/v1
CUSTOM_LLM_API_KEY=

# Web
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_STREAM_API_URL=http://127.0.0.1:8000
DOCUMIND_INTERNAL_API_URL=http://documind-api:8000
